# =============================================================================
# .env.example — Secrets & Sensitive Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values for your environment.
# NEVER commit .env to version control — it's already in .gitignore.
#
# ⚠️  This file houses ONLY secrets and sensitive values. All non-secret
#     configuration (pool sizes, timeouts, logging format, provider defaults,
#     retry settings, etc.) lives in config/*.yaml — NOT here.
#
# Generate a fresh encryption master key:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# =============================================================================


# ── Environment Selector ──────────────────────────────────────────────────────
# Tells the app which YAML overlay to load: config/environments/<value>.yaml
APP_ENVIRONMENT=development          # development | staging | production | test


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://llm_user:changeme-local-postgres-password@localhost:5432/llm_services

# docker-compose bootstrap variables used by the local Postgres container.
# The local infrastructure manager creates these in .env if they are missing.
POSTGRES_USER=llm_user
POSTGRES_PASSWORD=changeme-local-postgres-password
POSTGRES_DB=llm_services


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme-local-redis-password@localhost:6379/0
REDIS_PASSWORD=changeme-local-redis-password


# ── Secret Backend ────────────────────────────────────────────────────────
# Which SecretStore implementation to use: 'environment' (dev/test) or 'vault' (staging/prod)
SECRET_BACKEND=environment           # environment | vault


# ── HashiCorp Vault ───────────────────────────────────────────────────────
# Required when SECRET_BACKEND=vault. Must match vault-init service account.
VAULT_ADDR=http://localhost:8200
VAULT_USERNAME=llm-service
VAULT_PASSWORD=changeme-vault-service-password
VAULT_MOUNT_PATH=secret
VAULT_KV_PREFIX=llm-provider-service

# docker-compose bootstrap variables (used by vault and vault-init services, not the app)
VAULT_ROOT_TOKEN=dev-root-token-changeme
VAULT_SERVICE_USERNAME=llm-service
VAULT_SERVICE_PASSWORD=changeme-vault-service-password


# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte AES-256-GCM master key, base64-encoded.
# Used to derive per-tenant encryption keys via HKDF.
# Generate a fresh one with the command shown at the top of this file.
ENCRYPTION_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=


# ═════════════════════════════════════════════════════════════════════════════
# Provider API Keys
# ═════════════════════════════════════════════════════════════════════════════
# Used by EnvironmentSecretStore in dev/test only.
# In production these are stored encrypted in PostgreSQL and decrypted via
# AESGCMSecretStore — they will NOT be read from environment variables.

# ── Direct LLM Providers ──────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-ai-studio-api-key-here
# COHERE_API_KEY=your-cohere-api-key-here
# MISTRAL_API_KEY=your-mistral-api-key-here
# VOYAGE_API_KEY=your-voyage-embedding-api-key-here
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# TOGETHER_API_KEY=your-together-ai-api-key-here
# GROQ_API_KEY=your-groq-api-key-here
# VLLM_API_KEY=optional-self-hosted-vllm-api-key-here


# ═════════════════════════════════════════════════════════════════════════════
# Cloud Provider Credentials
# ═════════════════════════════════════════════════════════════════════════════

# ── AWS (needed for Bedrock and other AWS SDK–based providers) ────────────────
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_DEFAULT_REGION=us-east-1
# AWS_SESSION_TOKEN=              # optional, for temporary STS credentials


# ── Azure (needed for Azure OpenAI) ───────────────────────────────────────────
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01


# ── GCP (needed for Vertex AI and other GCP services) ─────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-key.json
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1


# ── JWT Authentication ────────────────────────────────────────────────────────
# Secret key for signing and verifying JWT tokens.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-real-secret-with-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
# JWT_REFRESH_ENABLED=false
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Observability ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
